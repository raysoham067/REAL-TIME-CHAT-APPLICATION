{
  "name": "relay-chat-backend",
  "version": "2.1.0",
  "description": "Production-ready real-time chat backend — Node.js + Socket.io + JWT + optional Redis",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:redis": "REDIS_URL=redis://localhost:6379 node src/server.js",
    "lint": "eslint src --ext .js",
    "test": "jest --forceExit",
    "keygen": "node -e \"const c=require('crypto'); console.log('JWT_SECRET='+c.randomBytes(64).toString('hex')); console.log('REFRESH_SECRET='+c.randomBytes(64).toString('hex'));\""
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "redis": "^5.11.0",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0"
  }
}
